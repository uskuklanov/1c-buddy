
# Gateway API key that clients must present (Authorization: Bearer <OPENAI_COMPAT_API_KEY>)
OPENAI_COMPAT_API_KEY=your_gateway_key

# 1C.ai upstream API token (from https://code.1c.ai)
ONEC_AI_TOKEN=your_1c_ai_token

# Upstream base URL and timeout
ONEC_AI_BASE_URL=https://code.1c.ai
ONEC_AI_TIMEOUT=30

# Upstream defaults
ONEC_AI_UI_LANGUAGE=russian
ONEC_AI_PROGRAMMING_LANGUAGE=
ONEC_AI_SCRIPT_LANGUAGE=

# Session management
MAX_ACTIVE_SESSIONS=10
SESSION_TTL=3600

# Public model id presented to clients at /v1/models
PUBLIC_MODEL_ID=1c-buddy

# Global input length limit for upstream (chat, OpenAI API and MCP)
ONEC_AI_INPUT_MAX_LENGTH=100000

# MCP tool input limits
MCP_TOOL_INPUT_MIN_LENGTH=4
MCP_TOOL_INPUT_MAX_LENGTH=100000

# MCP tool call mode: direct (exact upstream tool calls) or standard (prompt-based)
MCP_TOOL_CALL_MODE=direct

# Chat file attachments (maximum total size in KB)
MAX_ATTACHED_FILES_SIZE_KB=100

# Chat custom workspace instructions and external HTTP MCP servers
CHAT_CUSTOM_INSTRUCTIONS_ENABLED=false
CHAT_CUSTOM_MCP_ENABLED=false
CHAT_CUSTOM_INSTRUCTIONS_MAX_LENGTH=4000
CHAT_CUSTOM_MCP_MAX_SERVERS=10
CHAT_CUSTOM_MCP_MAX_TOOLS_PER_SERVER=100

# Outgoing HTTP/TLS configuration
# SSL_VERIFY=false disables server authenticity checks for ALL outgoing HTTPS
# requests (chat, OpenAI API, MCP). Emergency use only.
SSL_VERIFY=true

# Optional corporate proxy
# NO_PROXY should list local MCP servers so they are not routed through the proxy
# HTTP_PROXY=http://proxy.company.local:3128
# HTTPS_PROXY=http://proxy.company.local:3128
# NO_PROXY=localhost,127.0.0.1,host.docker.internal

# Optional trusted CA bundle mounted inside the container.
# Must be a full PEM bundle: when set, httpx stops using its built-in public CA
# list, so the file has to contain both the public CAs and the corporate CA.
# Ignored when SSL_VERIFY=false.
# SSL_CERT_FILE=/certs/company-ca-bundle.pem

# Logging
LOG_LEVEL=INFO
LOG_REQUEST_BODY_MAX_LENGTH=40000

# Optional project context for MCP prompts (leave empty to disable)
# DEFAULT_SSL_VERSION=3.1.5
# DEFAULT_1C_CONFIGURATION=1С:Бухгалтерия 8
